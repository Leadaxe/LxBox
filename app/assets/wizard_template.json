{
  "parser_config": {
    "version": 5,
    "parser": {
      "reload": "12h"
    }
  },

  "dns_options": {
    "servers": [
      {"type": "local", "tag": "local_dns_resolver", "description": "System DNS", "enabled": true},
      {"type": "udp", "tag": "direct_dns_resolver", "server": "8.8.8.8", "server_port": 53, "description": "Google DNS (direct)", "enabled": true},
      {"type": "udp", "tag": "cloudflare_udp", "server": "1.1.1.1", "server_port": 53, "description": "Cloudflare UDP", "enabled": true},
      {"type": "https", "tag": "google_doh", "server": "dns.google", "server_port": 443, "path": "/dns-query", "domain_resolver": "direct_dns_resolver", "description": "Google DoH", "enabled": true},
      {"type": "https", "tag": "yandex_doh", "server": "77.88.8.88", "server_port": 443, "path": "/dns-query", "domain_strategy": "prefer_ipv4", "description": "Yandex DoH", "enabled": true},
      {"type": "tls", "tag": "cloudflare_dot", "server": "1.1.1.1", "server_port": 853, "description": "Cloudflare DoT", "enabled": false},
      {"type": "tls", "tag": "google_dot", "server": "8.8.8.8", "server_port": 853, "description": "Google DoT", "enabled": false},
      {"type": "udp", "tag": "yandex_udp", "server": "77.88.8.8", "server_port": 53, "description": "Yandex UDP", "enabled": false},
      {"type": "udp", "tag": "yandex_safe", "server": "77.88.8.88", "server_port": 53, "description": "Yandex Safe (anti-phishing)", "enabled": false},
      {"type": "udp", "tag": "yandex_family", "server": "77.88.8.7", "server_port": 53, "description": "Yandex Family (+ adult block)", "enabled": false},
      {"type": "tls", "tag": "yandex_dot", "server": "common.dot.dns.yandex.net", "server_port": 853, "description": "Yandex DoT", "enabled": false},
      {"type": "tls", "tag": "quad9_dot", "server": "9.9.9.9", "server_port": 853, "description": "Quad9 (anti-malware)", "enabled": false},
      {"type": "tls", "tag": "adguard_dot", "server": "dns.adguard-dns.com", "server_port": 853, "description": "AdGuard (ad block)", "enabled": false},
      {"type": "tls", "tag": "adguard_family", "server": "family.adguard-dns.com", "server_port": 853, "description": "AdGuard Family (+ adult)", "enabled": false},
      {"type": "https", "tag": "google_doh_vpn", "server": "dns.google", "server_port": 443, "path": "/dns-query", "domain_resolver": "direct_dns_resolver", "detour": "vpn-1", "description": "Google DoH via VPN", "enabled": false},
      {"type": "udp", "tag": "yandex_vpn", "server": "77.88.8.2", "server_port": 53, "detour": "vpn-1", "domain_strategy": "prefer_ipv4", "description": "Yandex DNS via VPN", "enabled": false}
    ],
    "rules": [
      {"rule_set": "ru-domains", "server": "yandex_doh"},
      {"server": "google_doh"}
    ]
  },

  "ping_options": {
    "url": "https://www.gstatic.com/generate_204",
    "timeout_ms": 5000,
    "presets": [
      {"name": "Google 204", "url": "https://www.gstatic.com/generate_204"},
      {"name": "Cloudflare", "url": "https://cp.cloudflare.com/generate_204"},
      {"name": "Apple", "url": "https://captive.apple.com/hotspot-detect.html"},
      {"name": "Firefox", "url": "https://detectportal.firefox.com/canonical.html"},
      {"name": "Yandex", "url": "https://ya.ru/"}
    ]
  },

  "speed_test_options": {
    "servers": [
      {"name": "Cloudflare", "download_url": "https://speed.cloudflare.com/__down?bytes=25000000", "upload_url": "https://speed.cloudflare.com/__up", "upload_method": "POST", "ping_url": "https://speed.cloudflare.com/__down?bytes=0"},
      {"name": "Hostkey (Moscow)", "download_url": "https://spd-rudp.hostkey.ru/files/10mb.bin", "ping_url": "https://spd-rudp.hostkey.ru/"},
      {"name": "Selectel (RU)", "download_url": "https://speedtest.selectel.ru/10MB", "ping_url": "https://speedtest.selectel.ru/"},
      {"name": "Hostkey (Frankfurt)", "download_url": "https://spd-desrv.hostkey.com/files/10mb.bin", "ping_url": "https://spd-desrv.hostkey.com/"},
      {"name": "Hostkey (Amsterdam)", "download_url": "https://spd-nlsrv.hostkey.com/files/10mb.bin", "ping_url": "https://spd-nlsrv.hostkey.com/"},
      {"name": "Hostkey (Helsinki)", "download_url": "https://spd-fisrv.hostkey.com/files/10mb.bin", "ping_url": "https://spd-fisrv.hostkey.com/"},
      {"name": "Hostkey (New York)", "download_url": "https://spd-uswb.hostkey.com/files/10mb.bin", "ping_url": "https://spd-uswb.hostkey.com/"},
      {"name": "Tele2 (EU)", "download_url": "http://speedtest.tele2.net/10MB.zip", "upload_url": "http://speedtest.tele2.net/upload.php", "ping_url": "http://speedtest.tele2.net/"},
      {"name": "OVH (France)", "download_url": "https://proof.ovh.net/files/10Mb.dat", "ping_url": "https://proof.ovh.net/"},
      {"name": "ThinkBroadband (UK)", "download_url": "http://ipv4.download.thinkbroadband.com/10MB.zip", "ping_url": "http://ipv4.download.thinkbroadband.com/"}
    ],
    "stream_options": [1, 4, 10],
    "default_streams": 4
  },

  "preset_groups": [
    {
      "tag": "auto-proxy-out",
      "type": "urltest",
      "label": "Auto Proxy",
      "default_enabled": true,
      "options": {
        "url": "@urltest_url",
        "interval": "@urltest_interval",
        "tolerance": "@urltest_tolerance",
        "interrupt_exist_connections": true
      },
      "add_outbounds": []
    },
    {
      "tag": "vpn-1",
      "type": "selector",
      "label": "VPN ①",
      "default_enabled": true,
      "options": {
        "interrupt_exist_connections": true,
        "default": "auto-proxy-out"
      },
      "add_outbounds": ["direct-out", "auto-proxy-out"]
    },
    {
      "tag": "vpn-2",
      "type": "selector",
      "label": "VPN ②",
      "default_enabled": false,
      "options": {
        "default": "direct-out",
        "interrupt_exist_connections": true
      },
      "add_outbounds": ["direct-out", "auto-proxy-out"]
    },
    {
      "tag": "vpn-3",
      "type": "selector",
      "label": "VPN ③",
      "default_enabled": false,
      "options": {
        "default": "direct-out",
        "interrupt_exist_connections": true
      },
      "add_outbounds": ["direct-out", "auto-proxy-out"]
    }
  ],

  "vars": [
    { "section": "General", "description": "Logging and core settings" },
    {
      "name": "log_level",
      "type": "enum",
      "default_value": "warn",
      "options": ["trace", "debug", "info", "warn", "error", "fatal", "panic"],
      "wizard_ui": "edit",
      "title": "Log level",
      "tooltip": "Verbosity of sing-box logs"
    },
    { "section": "Clash API", "description": "Real-time proxy management interface" },
    {
      "name": "clash_api",
      "type": "text",
      "default_value": "127.0.0.1:9090",
      "wizard_ui": "edit",
      "title": "Address",
      "tooltip": "Host:port for Clash API"
    },
    {
      "name": "clash_secret",
      "type": "secret",
      "default_value": "",
      "wizard_ui": "edit",
      "title": "Secret",
      "tooltip": "Authentication secret for Clash API"
    },
    { "section": "Network", "description": "Connection and routing behavior" },
    {
      "name": "resolve_strategy",
      "type": "enum",
      "default_value": "prefer_ipv4",
      "options": ["prefer_ipv4", "prefer_ipv6", "ipv4_only", "ipv6_only"],
      "wizard_ui": "edit",
      "title": "Resolve strategy",
      "tooltip": "IP version preference for DNS resolution"
    },
    {
      "name": "auto_detect_interface",
      "type": "bool",
      "default_value": "true",
      "wizard_ui": "edit",
      "title": "Auto-detect interface",
      "tooltip": "Automatically detect the default network interface"
    },
    {
      "name": "sniff_enabled",
      "type": "bool",
      "default_value": "true",
      "wizard_ui": "edit",
      "title": "Packet sniffing",
      "tooltip": "Detect protocol and domain from packets for accurate routing"
    },
    { "section": "Auto Proxy", "description": "Automatic proxy selection (urltest)" },
    {
      "name": "urltest_url",
      "type": "text",
      "default_value": "https://cp.cloudflare.com/generate_204",
      "wizard_ui": "edit",
      "title": "Test URL",
      "tooltip": "Endpoint for measuring proxy latency"
    },
    {
      "name": "urltest_interval",
      "type": "text",
      "default_value": "5m",
      "wizard_ui": "edit",
      "title": "Test interval",
      "tooltip": "How often to check proxy latency (e.g. 30s, 1m, 5m)"
    },
    {
      "name": "urltest_tolerance",
      "type": "text",
      "default_value": "100",
      "wizard_ui": "edit",
      "title": "Tolerance (ms)",
      "tooltip": "Only switch proxy if latency difference exceeds this"
    },
    { "section": "DNS", "description": "Domain name resolution" },
    {
      "name": "dns_strategy",
      "type": "enum",
      "default_value": "prefer_ipv4",
      "options": ["prefer_ipv4", "prefer_ipv6", "ipv4_only", "ipv6_only"],
      "wizard_ui": "edit",
      "title": "Preferred IP version",
      "tooltip": "DNS resolution strategy"
    },
    {
      "name": "dns_independent_cache",
      "type": "bool",
      "default_value": "false",
      "wizard_ui": "fix",
      "title": "Independent DNS cache",
      "tooltip": "Separate cache per DNS server"
    },
    {
      "name": "dns_default_domain_resolver",
      "type": "text",
      "default_value": "cloudflare_udp",
      "wizard_ui": "fix",
      "title": "Default domain resolver",
      "tooltip": "DNS server tag for resolving domains in routing rules"
    },
    {
      "name": "dns_final",
      "type": "text",
      "default_value": "direct_dns_resolver",
      "wizard_ui": "fix",
      "title": "DNS final",
      "tooltip": "Fallback DNS server for unmatched queries"
    },
    { "section": "TUN", "description": "Virtual network interface" },
    {
      "name": "tun_address",
      "type": "text",
      "default_value": "172.16.0.1/30",
      "wizard_ui": "fix",
      "title": "IPv4 address",
      "tooltip": "TUN interface address (CIDR)"
    },
    {
      "name": "tun_mtu",
      "type": "text",
      "default_value": "1492",
      "wizard_ui": "edit",
      "title": "MTU",
      "tooltip": "1492 recommended for mobile/WiFi"
    },
    {
      "name": "tun_auto_route",
      "type": "bool",
      "default_value": "true",
      "wizard_ui": "fix",
      "title": "Auto route",
      "tooltip": "Let sing-box manage routing table"
    },
    {
      "name": "tun_strict_route",
      "type": "bool",
      "default_value": "false",
      "wizard_ui": "fix",
      "title": "Strict route",
      "tooltip": "May break connectivity on some devices"
    },
    {
      "name": "tun_stack",
      "type": "enum",
      "default_value": "system",
      "options": ["system", "gvisor", "mixed"],
      "wizard_ui": "edit",
      "title": "Stack",
      "tooltip": "system (default), gvisor (userspace), mixed"
    },
    { "section": "DPI Bypass", "description": "TLS fragmentation to bypass censorship" },
    {
      "name": "tls_fragment",
      "type": "bool",
      "default_value": "false",
      "wizard_ui": "edit",
      "title": "TLS Fragment",
      "tooltip": "Split TLS ClientHello into small TCP segments"
    },
    {
      "name": "tls_record_fragment",
      "type": "bool",
      "default_value": "false",
      "wizard_ui": "edit",
      "title": "TLS Record Fragment",
      "tooltip": "Split handshake into multiple TLS records (try this first)"
    },
    {
      "name": "tls_fragment_fallback_delay",
      "type": "text",
      "default_value": "500ms",
      "wizard_ui": "edit",
      "title": "Fallback delay",
      "tooltip": "Wait time when automatic detection fails"
    }
  ],

  "config": {
    "log": {
      "level": "@log_level",
      "timestamp": true
    },
    "dns": {
      "servers": [],
      "rules": [],
      "final": "@dns_final",
      "strategy": "@dns_strategy",
      "independent_cache": "@dns_independent_cache"
    },
    "inbounds": [
      {
        "type": "tun",
        "tag": "tun-in",
        "address": "@tun_address",
        "mtu": "@tun_mtu",
        "auto_route": "@tun_auto_route",
        "strict_route": "@tun_strict_route",
        "stack": "@tun_stack"
      }
    ],
    "endpoints": [],
    "outbounds": [
      { "type": "direct", "tag": "direct-out" }
    ],
    "route": {
      "find_process": true,
      "default_domain_resolver": "@dns_default_domain_resolver",
      "rule_set": [
        { "tag": "ru-domains", "type": "inline", "format": "domain_suffix", "rules": [{ "domain_suffix": ["ru", "xn--p1ai", "su"] }] }
      ],
      "rules": [
        { "action": "resolve", "inbound": "tun-in", "strategy": "@resolve_strategy" },
        { "action": "sniff", "inbound": "tun-in", "timeout": "1s" },
        { "protocol": "dns", "action": "hijack-dns" }
      ],
      "final": "vpn-1",
      "auto_detect_interface": "@auto_detect_interface"
    },
    "experimental": {
      "clash_api": {
        "external_controller": "@clash_api",
        "secret": "@clash_secret"
      },
      "cache_file": {
        "enabled": true,
        "path": "cache.db"
      }
    }
  },

  "selectable_rules": [
    {
      "label": "Block Ads",
      "description": "Reject ad-related connections. Downloads rule set (~1 MB).",
      "default": false,
      "rule_set": [
        { "tag": "ads-all", "type": "remote", "format": "binary", "url": "https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geosite/geosite-category-ads-all.srs" }
      ],
      "rule": { "rule_set": "ads-all", "action": "reject" }
    },
    {
      "label": "Russian domains direct",
      "description": "Route .ru / .su / .xn--p1ai directly.",
      "default": true,
      "rule": { "rule_set": "ru-domains", "outbound": "direct-out" }
    },
    {
      "label": "Russia-only services direct",
      "description": "Services available only inside Russia — direct.",
      "rule_set": [
        { "tag": "ru-inside", "type": "remote", "format": "binary", "url": "https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geosite/geosite-ru-available-only-inside.srs" }
      ],
      "rule": { "rule_set": "ru-inside", "outbound": "direct-out" }
    },
    {
      "label": "BitTorrent direct",
      "description": "Route BitTorrent traffic directly.",
      "default": true,
      "rule": { "protocol": ["bittorrent"], "outbound": "direct-out" }
    },
    {
      "label": "Private IPs direct",
      "description": "Route private IP ranges (LAN) directly.",
      "rule": { "ip_is_private": true, "outbound": "direct-out" }
    }
  ]
}
