{
  "parser_config": {
    "version": 5,
    "parser": {
      "reload": "12h"
    }
  },

  "preset_groups": [
    {
      "tag": "auto-proxy-out",
      "type": "urltest",
      "label": "Auto Proxy",
      "default_enabled": true,
      "options": {
        "url": "https://cp.cloudflare.com/generate_204",
        "interval": "5m",
        "tolerance": 100,
        "interrupt_exist_connections": true
      },
      "add_outbounds": []
    },
    {
      "tag": "proxy-out",
      "type": "selector",
      "label": "Proxy",
      "default_enabled": true,
      "options": {
        "interrupt_exist_connections": true,
        "default": "auto-proxy-out"
      },
      "add_outbounds": ["direct-out", "auto-proxy-out"]
    },
    {
      "tag": "vpn-1",
      "type": "selector",
      "label": "VPN ①",
      "default_enabled": false,
      "options": {
        "default": "direct-out",
        "interrupt_exist_connections": true
      },
      "add_outbounds": ["direct-out"]
    },
    {
      "tag": "vpn-2",
      "type": "selector",
      "label": "VPN ②",
      "default_enabled": false,
      "options": {
        "default": "direct-out",
        "interrupt_exist_connections": true
      },
      "add_outbounds": ["direct-out"]
    }
  ],

  "vars": [
    {
      "name": "log_level",
      "type": "enum",
      "default_value": "warn",
      "options": ["trace", "debug", "info", "warn", "error", "fatal", "panic"],
      "wizard_ui": "edit",
      "title": "Log level",
      "tooltip": "Sing-box log.level."
    },
    { "separator": true },
    {
      "name": "clash_api",
      "type": "text",
      "default_value": "127.0.0.1:9090",
      "wizard_ui": "edit",
      "title": "Clash API address",
      "tooltip": "Host:port for external_controller."
    },
    {
      "name": "clash_secret",
      "type": "secret",
      "default_value": "",
      "wizard_ui": "edit",
      "title": "Clash API secret",
      "tooltip": "Secret for the Clash API."
    },
    { "separator": true },
    {
      "name": "resolve_strategy",
      "type": "enum",
      "default_value": "prefer_ipv4",
      "options": ["prefer_ipv4", "prefer_ipv6", "ipv4_only", "ipv6_only"],
      "wizard_ui": "edit",
      "title": "Resolve strategy",
      "tooltip": "Resolution strategy for route rules."
    },
    {
      "name": "auto_detect_interface",
      "type": "bool",
      "default_value": "true",
      "wizard_ui": "edit",
      "title": "Auto-detect interface",
      "tooltip": "Detect default interface for outbound."
    },
    { "separator": true },
    {
      "name": "dns_strategy",
      "type": "enum",
      "default_value": "prefer_ipv4",
      "options": ["prefer_ipv4", "prefer_ipv6", "ipv4_only", "ipv6_only"],
      "wizard_ui": "fix",
      "title": "DNS strategy",
      "tooltip": "sing-box config.dns.strategy."
    },
    {
      "name": "dns_independent_cache",
      "type": "bool",
      "default_value": "false",
      "wizard_ui": "fix",
      "title": "Independent DNS cache",
      "tooltip": "sing-box config.dns.independent_cache."
    },
    {
      "name": "dns_default_domain_resolver",
      "type": "text",
      "default_value": "direct_dns_resolver",
      "wizard_ui": "fix",
      "title": "Default DNS domain resolver",
      "tooltip": "sing-box config.route.default_domain_resolver."
    },
    {
      "name": "dns_final",
      "type": "text",
      "default_value": "direct_dns_resolver",
      "wizard_ui": "fix",
      "title": "DNS final",
      "tooltip": "sing-box config.dns.final."
    }
  ],

  "config": {
    "log": {
      "level": "@log_level",
      "timestamp": true
    },
    "dns": {
      "servers": [
        { "type": "local", "tag": "local_dns_resolver" },
        { "type": "udp", "tag": "direct_dns_resolver", "server": "8.8.8.8", "server_port": 53 },
        {
          "type": "https",
          "tag": "google_doh",
          "server": "dns.google",
          "server_port": 443,
          "path": "/dns-query",
          "domain_resolver": "direct_dns_resolver"
        },
        {
          "type": "https",
          "tag": "yandex_doh",
          "server": "77.88.8.88",
          "server_port": 443,
          "path": "/dns-query",
          "domain_strategy": "prefer_ipv4"
        }
      ],
      "rules": [
        { "rule_set": "ru-domains", "server": "yandex_doh" },
        { "server": "google_doh" }
      ],
      "final": "@dns_final",
      "strategy": "@dns_strategy",
      "independent_cache": "@dns_independent_cache"
    },
    "inbounds": [],
    "endpoints": [],
    "outbounds": [
      { "type": "direct", "tag": "direct-out" }
    ],
    "route": {
      "default_domain_resolver": "@dns_default_domain_resolver",
      "rule_set": [
        { "tag": "ru-domains", "type": "inline", "format": "domain_suffix", "rules": [{ "domain_suffix": ["ru", "xn--p1ai", "su"] }] }
      ],
      "rules": [
        { "protocol": "dns", "action": "hijack-dns" }
      ],
      "final": "proxy-out",
      "auto_detect_interface": "@auto_detect_interface"
    },
    "experimental": {
      "clash_api": {
        "external_controller": "@clash_api",
        "secret": "@clash_secret"
      },
      "cache_file": {
        "enabled": true,
        "path": "cache.db"
      }
    }
  },

  "selectable_rules": [
    {
      "label": "Block Ads",
      "description": "Reject ad-related connections.",
      "default": true,
      "rule_set": [
        { "tag": "ads-all", "type": "remote", "format": "binary", "url": "https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geosite/geosite-category-ads-all.srs" }
      ],
      "rule": { "rule_set": "ads-all", "action": "reject" }
    },
    {
      "label": "Russian domains direct",
      "description": "Route .ru / .su / .xn--p1ai directly.",
      "default": true,
      "rule": { "rule_set": "ru-domains", "outbound": "direct-out" }
    },
    {
      "label": "Russia-only services direct",
      "description": "Services available only inside Russia — direct.",
      "rule_set": [
        { "tag": "ru-inside", "type": "remote", "format": "binary", "url": "https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geosite/geosite-ru-available-only-inside.srs" }
      ],
      "rule": { "rule_set": "ru-inside", "outbound": "direct-out" }
    },
    {
      "label": "Russian blocked resources via proxy",
      "description": "Route resources blocked in Russia through proxy.",
      "rule_set": [
        { "tag": "ru-blocked-main", "type": "remote", "format": "binary", "url": "https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geoip/geoip-ru-blocked.srs" },
        { "tag": "ru-blocked-community", "type": "remote", "format": "binary", "url": "https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geoip/geoip-ru-blocked-community.srs" }
      ],
      "rule": { "rule_set": ["ru-blocked-main", "ru-blocked-community"], "network": ["tcp", "udp"], "outbound": "proxy-out" }
    },
    {
      "label": "Messengers via proxy",
      "description": "Telegram, WhatsApp, Discord, Signal through proxy.",
      "rule_set": [
        {
          "tag": "messengers",
          "type": "inline",
          "format": "domain_suffix",
          "rules": [
            {
              "domain_suffix": [
                "telegram.org", "t.me", "cdn-telegram.org",
                "web.whatsapp.com", "whatsapp.com", "whatsapp.net",
                "discord.com", "discordapp.com", "discord.gg", "discord.media",
                "signal.org", "whispersystems.org"
              ]
            }
          ]
        }
      ],
      "rule": { "rule_set": "messengers", "network": ["tcp", "udp"], "outbound": "proxy-out" }
    },
    {
      "label": "BitTorrent direct",
      "description": "Route BitTorrent traffic directly.",
      "default": true,
      "rule": { "protocol": ["bittorrent"], "outbound": "direct-out" }
    },
    {
      "label": "Private IPs direct",
      "description": "Route private IP ranges (LAN) directly.",
      "rule": { "ip_is_private": true, "outbound": "direct-out" }
    },
    {
      "label": "2ip.io via proxy",
      "description": "Check VPN IP via 2ip.io.",
      "rule": { "domain": ["2ip.io"], "outbound": "proxy-out" }
    },
    {
      "label": "2ip.ru direct",
      "description": "Check real IP via 2ip.ru.",
      "rule": { "domain": ["2ip.ru"], "outbound": "direct-out" }
    },
    {
      "label": "Stop HTTP/3 (QUIC)",
      "description": "Drop UDP:443 — QUIC can't be proxied, may improve stability.",
      "rule": { "action": "reject", "method": "drop", "network": ["udp"], "port": [443] }
    }
  ]
}
