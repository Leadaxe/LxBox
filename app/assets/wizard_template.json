{
  "parser_config": {
    "version": 5,
    "parser": {
      "reload": "12h"
    }
  },

  "preset_groups": [
    {
      "tag": "auto-proxy-out",
      "type": "urltest",
      "label": "Auto Proxy",
      "default_enabled": true,
      "options": {
        "url": "https://cp.cloudflare.com/generate_204",
        "interval": "5m",
        "tolerance": 100,
        "interrupt_exist_connections": true
      },
      "add_outbounds": []
    },
    {
      "tag": "proxy-out",
      "type": "selector",
      "label": "Proxy",
      "default_enabled": true,
      "options": {
        "interrupt_exist_connections": true,
        "default": "auto-proxy-out"
      },
      "add_outbounds": ["direct-out", "auto-proxy-out"]
    },
    {
      "tag": "vpn-1",
      "type": "selector",
      "label": "VPN ①",
      "default_enabled": false,
      "options": {
        "default": "direct-out",
        "interrupt_exist_connections": true
      },
      "add_outbounds": ["direct-out"]
    },
    {
      "tag": "vpn-2",
      "type": "selector",
      "label": "VPN ②",
      "default_enabled": false,
      "options": {
        "default": "direct-out",
        "interrupt_exist_connections": true
      },
      "add_outbounds": ["direct-out"]
    }
  ],

  "vars": [
    {
      "name": "log_level",
      "type": "enum",
      "default_value": "warn",
      "options": ["trace", "debug", "info", "warn", "error", "fatal", "panic"],
      "wizard_ui": "edit",
      "title": "Log level",
      "tooltip": "Sing-box log.level."
    },
    { "separator": true },
    {
      "name": "clash_api",
      "type": "text",
      "default_value": "127.0.0.1:9090",
      "wizard_ui": "edit",
      "title": "Clash API address",
      "tooltip": "Host:port for external_controller."
    },
    {
      "name": "clash_secret",
      "type": "secret",
      "default_value": "",
      "wizard_ui": "edit",
      "title": "Clash API secret",
      "tooltip": "Secret for the Clash API."
    },
    { "separator": true },
    {
      "name": "resolve_strategy",
      "type": "enum",
      "default_value": "prefer_ipv4",
      "options": ["prefer_ipv4", "prefer_ipv6", "ipv4_only", "ipv6_only"],
      "wizard_ui": "edit",
      "title": "Resolve strategy",
      "tooltip": "Resolution strategy for route rules."
    },
    {
      "name": "auto_detect_interface",
      "type": "bool",
      "default_value": "true",
      "wizard_ui": "edit",
      "title": "Auto-detect interface",
      "tooltip": "Detect default interface for outbound."
    },
    { "separator": true },
    {
      "name": "dns_strategy",
      "type": "enum",
      "default_value": "prefer_ipv4",
      "options": ["prefer_ipv4", "prefer_ipv6", "ipv4_only", "ipv6_only"],
      "wizard_ui": "fix",
      "title": "DNS strategy",
      "tooltip": "sing-box config.dns.strategy."
    },
    {
      "name": "dns_independent_cache",
      "type": "bool",
      "default_value": "false",
      "wizard_ui": "fix",
      "title": "Independent DNS cache",
      "tooltip": "sing-box config.dns.independent_cache."
    },
    {
      "name": "dns_default_domain_resolver",
      "type": "text",
      "default_value": "cloudflare_udp",
      "wizard_ui": "fix",
      "title": "Default DNS domain resolver",
      "tooltip": "Tag of a DNS server used to resolve domain names in routing (must exist in dns.servers). cloudflare_udp matches typical libbox/Android setups."
    },
    {
      "name": "dns_final",
      "type": "text",
      "default_value": "direct_dns_resolver",
      "wizard_ui": "fix",
      "title": "DNS final",
      "tooltip": "sing-box config.dns.final."
    },
    { "separator": true },
    {
      "name": "tun_address",
      "type": "text",
      "default_value": "172.16.0.1/30",
      "wizard_ui": "fix",
      "title": "TUN IPv4 address",
      "tooltip": "Single CIDR string for tun address (not a JSON array). 172.16.0.1/30 is commonly used on Android/libbox; 172.19.x is an alternative if your provider requires it."
    },
    {
      "name": "tun_mtu",
      "type": "text",
      "default_value": "1492",
      "wizard_ui": "fix",
      "title": "TUN MTU",
      "tooltip": "Typical 1492 avoids black holes on mobile/Wi‑Fi; very large MTU (e.g. 9000) often breaks tunnel traffic."
    },
    {
      "name": "tun_auto_route",
      "type": "bool",
      "default_value": "true",
      "wizard_ui": "fix",
      "title": "TUN auto_route",
      "tooltip": "Let sing-box manage default routes through the tunnel."
    },
    {
      "name": "tun_strict_route",
      "type": "bool",
      "default_value": "false",
      "wizard_ui": "fix",
      "title": "TUN strict_route",
      "tooltip": "true can break connectivity on some Android/VPN setups; false matches many working libbox configs."
    },
    {
      "name": "tun_stack",
      "type": "enum",
      "default_value": "system",
      "options": ["system", "gvisor", "mixed"],
      "wizard_ui": "fix",
      "title": "TUN stack",
      "tooltip": "sing-box tun stack: system (typical on Android), gvisor, or mixed."
    }
  ],

  "config": {
    "log": {
      "level": "@log_level",
      "timestamp": true
    },
    "dns": {
      "servers": [
        { "type": "local", "tag": "local_dns_resolver" },
        { "type": "udp", "tag": "direct_dns_resolver", "server": "8.8.8.8", "server_port": 53 },
        {
          "type": "udp",
          "tag": "cloudflare_udp",
          "server": "1.1.1.1",
          "server_port": 53
        },
        {
          "type": "https",
          "tag": "google_doh",
          "server": "dns.google",
          "server_port": 443,
          "path": "/dns-query",
          "domain_resolver": "direct_dns_resolver"
        },
        {
          "type": "https",
          "tag": "yandex_doh",
          "server": "77.88.8.88",
          "server_port": 443,
          "path": "/dns-query",
          "domain_strategy": "prefer_ipv4"
        }
      ],
      "rules": [
        { "rule_set": "ru-domains", "server": "yandex_doh" },
        { "server": "google_doh" }
      ],
      "final": "@dns_final",
      "strategy": "@dns_strategy",
      "independent_cache": "@dns_independent_cache"
    },
    "inbounds": [
      {
        "type": "tun",
        "tag": "tun-in",
        "address": "@tun_address",
        "mtu": "@tun_mtu",
        "auto_route": "@tun_auto_route",
        "strict_route": "@tun_strict_route",
        "stack": "@tun_stack"
      }
    ],
    "endpoints": [],
    "outbounds": [
      { "type": "direct", "tag": "direct-out" }
    ],
    "route": {
      "default_domain_resolver": "@dns_default_domain_resolver",
      "rule_set": [
        { "tag": "ru-domains", "type": "inline", "format": "domain_suffix", "rules": [{ "domain_suffix": ["ru", "xn--p1ai", "su"] }] }
      ],
      "rules": [
        { "action": "resolve", "inbound": "tun-in", "strategy": "@resolve_strategy" },
        { "action": "sniff", "inbound": "tun-in", "timeout": "1s" },
        { "protocol": "dns", "action": "hijack-dns" }
      ],
      "final": "proxy-out",
      "auto_detect_interface": "@auto_detect_interface"
    },
    "experimental": {
      "clash_api": {
        "external_controller": "@clash_api",
        "secret": "@clash_secret"
      },
      "cache_file": {
        "enabled": true,
        "path": "cache.db"
      }
    }
  },

  "selectable_rules": [
    {
      "label": "Block Ads",
      "description": "Reject ad-related connections.",
      "default": true,
      "rule_set": [
        { "tag": "ads-all", "type": "remote", "format": "binary", "url": "https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geosite/geosite-category-ads-all.srs" }
      ],
      "rule": { "rule_set": "ads-all", "action": "reject" }
    },
    {
      "label": "Russian domains direct",
      "description": "Route .ru / .su / .xn--p1ai directly.",
      "default": true,
      "rule": { "rule_set": "ru-domains", "outbound": "direct-out" }
    },
    {
      "label": "Russia-only services direct",
      "description": "Services available only inside Russia — direct.",
      "rule_set": [
        { "tag": "ru-inside", "type": "remote", "format": "binary", "url": "https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geosite/geosite-ru-available-only-inside.srs" }
      ],
      "rule": { "rule_set": "ru-inside", "outbound": "direct-out" }
    },
    {
      "label": "BitTorrent direct",
      "description": "Route BitTorrent traffic directly.",
      "default": true,
      "rule": { "protocol": ["bittorrent"], "outbound": "direct-out" }
    },
    {
      "label": "Private IPs direct",
      "description": "Route private IP ranges (LAN) directly.",
      "rule": { "ip_is_private": true, "outbound": "direct-out" }
    }
  ]
}
