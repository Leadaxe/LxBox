<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon для launcher long-press shortcut «Disconnect».
  Background — красная заливка, foreground — белый ■ glyph с inset.
  Без `<monochrome>` — themed-icons не активируются, цвета сохраняются.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/qc_disconnect_bg" />
    <foreground>
        <inset
            android:drawable="@drawable/ic_qc_stop"
            android:inset="20%" />
    </foreground>
</adaptive-icon>
